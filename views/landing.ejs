<% layout('layouts/landing') %>

<% if (isAuthenticated) { %>
    <!-- Logged In Hero Section -->
    <section class="hero-section">
        <div class="container text-center">
            <h1 class="display-4 fw-bold mb-4">Welcome back, <span class="text-primary"><%= username %></span>!</h1>
            <p class="lead mb-4">Ready to continue your fitness journey? Track your workouts, log your meals, and stay on top of your goals.</p>
            <div class="d-flex gap-3 justify-content-center">
                <a href="/workouts" class="btn btn-primary btn-lg">My Workouts</a>
                <a href="/food/diary" class="btn btn-outline-primary btn-lg">Food Diary</a>
            </div>
        </div>
    </section>
<% } else { %>
    <!-- Guest Hero Section -->
    <section class="hero-section">
        <div class="container text-center">
            <h1 class="display-4 fw-bold mb-4">Track Your Fitness Journey</h1>
            <p class="lead mb-4">Create custom workouts, calculate your calorie needs, and stay motivated with our complete fitness tracker.</p>
            <div class="d-flex gap-3 justify-content-center">
                <a href="/auth/register" class="btn btn-primary btn-lg">Get Started Free</a>
                <a href="/#features" class="btn btn-outline-primary btn-lg">Learn More</a>
            </div>
        </div>
    </section>
<% } %>

<!-- Features Section -->
<section id="features" class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Everything you need to stay fit</h2>
            <p class="text-muted">Simple tools that actually work</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card feature-card p-4 text-center">
                    <div class="feature-icon">⏱️</div>
                    <h5>Smart Timer</h5>
                    <p  >Built-in workout timer with rest periods. Never lose track of your sets again.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card feature-card p-4 text-center">
                    <div class="feature-icon">💪</div>
                    <h5>Custom Workouts</h5>
                    <p  >Build your own routines with our exercise library. Perfect for any fitness level.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card feature-card p-4 text-center">
                    <div class="feature-icon">📊</div>
                    <h5>Calorie Calculator</h5>
                    <p  >Calculate your daily calorie needs for weight loss, maintenance, or muscle gain.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card feature-card p-4 text-center">
                    <div class="feature-icon">📱</div>
                    <h5>Mobile Ready</h5>
                    <p  >Works great on your phone. Take your workouts anywhere, no app download needed.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card feature-card p-4 text-center">
                    <div class="feature-icon">🎯</div>
                    <h5>Goal Tracking</h5>
                    <p  >Set and track your fitness goals with personalized calorie and workout plans.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card feature-card p-4 text-center">
                    <div class="feature-icon">📈</div>
                    <h5>Progress Insights</h5>
                    <p  >Monitor your workout history and see your fitness journey unfold over time.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- New Calorie Calculator Preview Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h3 class="fw-bold mb-3">🧮 Smart Calorie Calculator</h3>
                <p class="mb-4">Get personalized daily calorie targets based on your goals. Our calculator uses the proven Mifflin-St Jeor equation and considers your activity level.</p>
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <div class="bg-success text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                📉
                            </div>
                            <div>
                                <strong>Weight Loss</strong><br>
                                <small class="text-muted">Safe deficit for gradual loss</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <div class="bg-info text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                ⚖️
                            </div>
                            <div>
                                <strong>Maintenance</strong><br>
                                <small class="text-muted">Stay at current weight</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <div class="bg-warning text-dark rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                📈
                            </div>
                            <div>
                                <strong>Muscle Gain</strong><br>
                                <small class="text-muted">Controlled surplus for lean gains</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                🔥
                            </div>
                            <div>
                                <strong>BMR Tracking</strong><br>
                                <small class="text-muted">Your metabolic baseline</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h5 class="text-center mb-3">Quick Preview</h5>
                        <div class="row g-3">
                            <div class="col-4">
                                <div class="text-center p-3 bg-success bg-opacity-10 rounded">
                                    <div class="text-success fw-bold">1,800</div>
                                    <small>Weight Loss</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="text-center p-3 bg-info bg-opacity-10 rounded">
                                    <div class="text-info fw-bold">2,300</div>
                                    <small>Maintenance</small>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="text-center p-3 bg-warning bg-opacity-10 rounded">
                                    <div class="text-warning fw-bold">2,600</div>
                                    <small>Muscle Gain</small>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-3">
                            <small class="text-muted">*Example for 25yo, 70kg, moderately active</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Demo Section -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h3 class="fw-bold mb-3">See it in action</h3>
                <p class="mb-4">Create your first workout in under 2 minutes. Add exercises, set your reps and weights, then hit start when you're ready to go.</p>
                <ul class="list-unstyled">
                    <li class="mb-2">✓ Add exercises with autocomplete</li>
                    <li class="mb-2">✓ Set custom rest times</li>
                    <li class="mb-2">✓ Calculate personalized calories</li>
                    <li class="mb-2">✓ Track your progress</li>
                    <li class="mb-2">✓ Complete workout history</li>
                </ul>
            </div>
        </div>
    </div>
</section>


<%- include('partials/footer') %>